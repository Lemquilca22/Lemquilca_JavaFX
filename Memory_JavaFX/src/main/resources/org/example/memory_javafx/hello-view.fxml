<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.memory_javafx.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="Memory" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

<!-- Aprendí que GridPane es para utilizar la estructura en filas y columnas -->
    <GridPane fx:id="gridTablero" hgap="10" vgap="10" alignment="CENTER"></GridPane>
</VBox>
